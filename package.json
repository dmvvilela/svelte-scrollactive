{
	"name": "svelte-scrollactive",
	"version": "0.1.0",
	"title": "Svelte Scrollactive",
	"description": "Lightweight and simple to use Svelte component that highlights menu items as you scroll the page, also scrolling to target section when clicked.",
	"scripts": {
		"dev": "vite dev",
		"build": "svelte-kit sync && svelte-package",
		"prepublishOnly": "echo 'Did you mean to publish `./package/`, instead of `./`?' && exit 1",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/dmvvilela/svelte-scrollactive.git"
	},
	"keywords": [
		"svelte",
		"svelte-plugin",
		"svelte-component",
		"scrollspy",
		"scroll",
		"active",
		"active-class",
		"menu-item",
		"highlight-menu-item"
	],
	"author": {
		"name": "Daniel Vilela",
		"email": "dmvvilela@gmail.com"
	},
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/dmvvilela/svelte-scrollactive/issues"
	},
	"homepage": "https://github.com/dmvvilela/svelte-scrollactive#readme",
	"svelte": "./dist/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"dependencies": {
		"bezier-easing": "^2.0.3"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^4.0.0",
		"@sveltejs/kit": "^2.0.0",
		"@sveltejs/package": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"eslint": "^9.0.0",
		"eslint-config-prettier": "^10.0.0",
		"eslint-plugin-svelte": "^3.0.0",
		"globals": "^16.0.0",
		"prettier": "^3.0.0",
		"prettier-plugin-svelte": "^3.5.0",
		"sass": "^1.58.0",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.0.0",
		"vite": "^6.0.0"
	},
	"type": "module"
}
